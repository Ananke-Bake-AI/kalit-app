{
  "name": "@kalit/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Kalit Studio desktop app",
  "homepage": "https://kalit.ai",
  "author": {
    "name": "Merkle Tech Labs LTD.",
    "email": "contact@kalit.ai"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:all": "electron-vite build && electron-builder -mwl",
    "build:all:x64": "electron-vite build && electron-builder --x64 -mwl",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kalit/broker-client": "workspace:*",
    "@kalit/i18n": "workspace:*",
    "@kalit/studio-ui": "workspace:*",
